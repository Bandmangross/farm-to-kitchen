# Copy this file to ".env" and fill in your values.

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/farm_to_kitchen

# Secret used to sign JWT auth tokens — use a long random string
JWT_SECRET=change_this_to_a_long_random_secret

# Paystack SECRET key (sk_test_... or sk_live_...) — used server-side to verify payments
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server port and the origin allowed by CORS (your client URL)
PORT=5050
CLIENT_ORIGIN=http://localhost:3000

# Credentials used by `npm run seed` to create the first admin user
SEED_ADMIN_EMAIL=admin@farmtokitchen.com
SEED_ADMIN_PASSWORD=admin1234
