# Copy this file to ".env" and fill in your values.

# ── Environment ──
# "development" or "production". In production the server REFUSES to start unless
# BOTH the payment and authentication configuration below are safe. These fail-fast
# guards keep an unsafe build out of production.
NODE_ENV=development

# ── Database ──
# MongoDB connection string. Transactions (used by the secure commerce path) require
# a replica set — MongoDB Atlas works out of the box; a bare local mongod does not.
MONGODB_URI=mongodb://127.0.0.1:27017/farm_to_kitchen

# ── Auth: JWT signing secret (CRITICAL) ──
# Signs access tokens. If this is the default/weak, anyone can FORGE admin tokens.
# Production requires a strong, non-default value (>= 32 chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The boot guard refuses to start in production if this is default/weak.
JWT_SECRET=change_this_to_a_long_random_secret

# ── Auth: token lifetimes (optional; safe defaults) ──
# ACCESS_TTL=15m
# ADMIN_ACCESS_TTL=45m
# REFRESH_TTL_DAYS=30

# ── Auth: admin MFA (TOTP) ──
# Turn on per-admin two-factor. When true, MFA_ENC_KEY (>= 32 bytes) is REQUIRED —
# it encrypts each admin's TOTP secret at rest. The boot guard enforces this in prod.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENABLE_ADMIN_MFA=true
MFA_ENC_KEY=replace_with_a_32_byte_random_hex_string

# ── Auth: password reset & email verification ──
# Both send email, so in production they REQUIRE a mail provider (below) AND a public
# APP_URL (used to build the reset/verify links). The boot guard enforces this in prod.
ENABLE_PASSWORD_RESET=true
ENABLE_EMAIL_VERIFICATION=true
APP_URL=http://localhost:5050

# Order gate: require a signed-in customer with BOTH email AND phone verified before
# ordering. Leave OFF unless phone verification (Twilio) is configured AND you intend
# to drop guest checkout — enabling it blocks all unverified/guest orders.
# ENABLE_ORDER_VERIFICATION_GATE=false

# Mail provider — Resend (preferred) OR AWS SES. Required in production when password
# reset / email verification are on.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM="Farm To Kitchen <no-reply@your-domain.com>"
# AWS_REGION=eu-west-1
# SES_FROM=no-reply@your-domain.com

# DEV ONLY — echo the verify/reset code+link in the API response so you can test
# without a real mailer. MUST be false/unset in production.
EMAIL_DEV_ECHO=true
PWRESET_DEV_ECHO=true

# ── Auth: protections (default ON; set "false" to disable) ──
# ENABLE_LOCKOUT=true          # account lockout after repeated bad passwords
# ENABLE_RATE_LIMIT=true       # per-IP rate limiting on auth routes
# ENABLE_AUDIT=true            # AuthAuditLog security event logging
# ENABLE_REFRESH_TOKENS=true   # rotating refresh-token sessions
# HIBP_ENABLED=true            # block known-breached passwords

# ── Paystack (payments) ──
# SERVER-SIDE SECRET key. Use sk_test_... in dev and sk_live_... in production.
# Never expose this to the browser. Used to verify charges and webhook signatures.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secure, server-authoritative commerce path: gateway verification, MongoDB
# transactions, idempotency, stock reserve/commit, reconciliation + sweeper jobs.
# MUST be "true" in production.
ENABLE_COMMERCE_INTEGRITY=true

# Paystack webhook endpoint (POST /api/payments/webhook). Signature-verified
# settlement safety net for charges where the browser closed before confirm.
# MUST be "true" in production. Also register the URL in the Paystack dashboard.
ENABLE_PAYMENT_WEBHOOK=true

# Accept "SIMULATED-..." references WITHOUT calling Paystack — LOCAL TESTING ONLY.
# MUST be "false" (or unset) in production. The boot guard refuses to start if this
# is true in production, or if it is true while a LIVE key is configured.
ALLOW_SIMULATED_PAYMENTS=false

# Optional commerce tuning (safe defaults shown).
# RESERVATION_TTL_MIN=30          # how long a stock reservation is held
# RECONCILE_INTERVAL_MS=300000    # how often unsettled paid orders are re-checked
# DEFAULT_DELIVERY_FEE=3000
# ENABLE_GATEWAY_REFUND=false     # call Paystack refund API on admin refund

# ── Server / CORS ──
PORT=5050
CLIENT_ORIGIN=http://localhost:3000

# ── First admin (created by `npm run seed`) ──
SEED_ADMIN_EMAIL=admin@farmtokitchen.com
SEED_ADMIN_PASSWORD=admin1234
